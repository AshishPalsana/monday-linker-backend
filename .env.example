DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/monday_linker"

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# For Monday.com embedded app, allow their iframe origins
ALLOWED_ORIGINS="http://localhost:5173,https://your-monday-app-domain.com"

# Monday.com App credentials
MONDAY_API_TOKEN="your_monday_api_token_here"
MONDAY_SIGNING_SECRET="your_monday_app_signing_secret"
MONDAY_CLIENT_ID="your_monday_client_id"
MONDAY_CLIENT_SECRET="your_monday_client_secret"

# JWT (used to issue short-lived session tokens after Monday identity check)
JWT_SECRET="change_this_to_a_long_random_string_in_production"
JWT_EXPIRES_IN="8h"

# Xero Integration
XERO_CLIENT_ID="PASTE_YOUR_XERO_CLIENT_ID_HERE"
XERO_CLIENT_SECRET="PASTE_YOUR_XERO_CLIENT_SECRET_HERE"
XERO_REDIRECT_URI="https://monday-linker-backend.onrender.com/api/xero/callback"
